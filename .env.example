# Kopiere diese Datei zu .env.local und fuelle die Werte aus:
# cp .env.example .env.local
#
# Hinweis: Das Projekt ist laut CLAUDE.md client-only, ohne Backend, ohne API-Keys.
# Diese Datei ist nur Platzhalter fuer den Fall, dass z.B. ein alternativer OSRM-Host
# genutzt werden soll.

# Alternativer OSRM-Host (default: public demo)
# NEXT_PUBLIC_OSRM_URL=https://router.project-osrm.org

# MapLibre Style-URL (falls nicht der Default verwendet wird)
# NEXT_PUBLIC_MAP_STYLE=
